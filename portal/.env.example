# ---------------------------------------------------------------------------
# QA Portal configuration. Copy to .env.local and fill in. NEVER commit secrets.
# ---------------------------------------------------------------------------

# --- VLM provider (screenshot assessment) ---
# Two options. If OPENROUTER_API_KEY is set it takes precedence and VLM_MODEL
# must be an OpenRouter slug (e.g. "google/gemma-4-31b-it:free" for a no-credit
# free model, or "google/gemini-2.5-flash" if the account has credits).
# Otherwise the Google Gemini direct key is used and VLM_MODEL is a Gemini id.
OPENROUTER_API_KEY=
GOOGLE_API_KEY=your-gemini-api-key
VLM_MODEL=google/gemma-4-31b-it:free

# --- Self-heal (Claude Code CLI, subscription auth — no API key) ---
# Absolute path to the `claude` binary. Only needed for the Self-heal button.
# Find it with `which claude` (often under ~/.nvm/versions/node/<v>/bin/claude).
CLAUDE_CLI_PATH=

# Optional: switch which Claude account Self-heal runs under, from the portal.
# Each points at a separate CLAUDE_CONFIG_DIR you've logged into ONCE with that
# account:  CLAUDE_CONFIG_DIR=/path/to/dir claude /login
# Leave blank to only offer the CLI's default login (~/.claude).
CLAUDE_CONFIG_DIR_BUSINESS=
CLAUDE_CONFIG_DIR_PERSONAL=

# --- GitHub (clone private repos) ---
# A fine-grained or classic PAT with "repo" (read) scope. Used only to clone;
# never logged. Leave blank for public repos.
GITHUB_TOKEN=

# --- Jira auto-dispatch (optional) ---
# Basic auth = email + API token from id.atlassian.net/manage/api-tokens
JIRA_BASE_URL=https://almosafer.atlassian.net
JIRA_EMAIL=you@almosafer.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=QA               # tickets are created under this project
JIRA_ISSUE_TYPE=Bug

# --- Slack auto-dispatch (optional) ---
# Incoming webhook URL: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# --- Access gate ---
# Shared password for the whole portal (HTTP Basic Auth, any username). Set this
# before sharing the app over a public tunnel/URL. Leave BLANK to disable the
# gate (fine for localhost-only dev).
PORTAL_PASSWORD=

# --- Runtime ---
# Where cloned repos + screenshots are written (relative to project root).
WORKSPACE_DIR=.workspaces

# --- VLM quota guard ---
# Each screenshot costs one Gemini call per active lens (free tier = 20/day).
# VLM_MAX_SCREENSHOTS caps how many screens are assessed per run (blank/0 = all).
# VLM_LENSES restricts lenses (comma list of: uiux, arabic, i18n; blank = all).
VLM_MAX_SCREENSHOTS=
VLM_LENSES=

# --- Slack Auto-fix bot (scripts/slack-autofix-bot.mjs) ---
# Create the app from scripts/slack-autofix-manifest.json (api.slack.com/apps →
# Create New App → From an app manifest), install to workspace, then:
SLACK_BOT_TOKEN=            # OAuth & Permissions → Bot User OAuth Token (xoxb-)
SLACK_APP_TOKEN=            # Basic Information → App-Level Tokens → connections:write (xapp-)
SLACK_AUTOFIX_CHANNEL=#hotel-cypress-logs
AUTOFIX_REPO=tajawal/qa-frontend-cypress
AUTOFIX_BRANCH=master

# --- Quality dashboard report access (report-driven Slack picker) ---
# The bot reads per-spec failure detail from quality.almosafer.io reports.
# "Public" report pages still need an Okta session, so paste a logged-in
# browser's Cookie header here (DevTools → Network → any request → cookie).
QUALITY_URL=https://quality.almosafer.io
QUALITY_COOKIE=
