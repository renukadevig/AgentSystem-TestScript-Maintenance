SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_USER_TOKEN=
SLACK_AUTOFIX_CHANNEL=
PORTAL_URL=
AUTOFIX_REPO=
AUTOFIX_BRANCH=
AUTOFIX_SPEC_FILTER=
# cypress (default) or playwright — drives fix prompts + verification runner
AUTOFIX_FRAMEWORK=cypress
AUTOFIX_ANALYSIS_MODEL=
QUALITY_URL=
QUALITY_COOKIE=
GITHUB_TOKEN=
CLAUDE_CLI_PATH=

# Optional: per-channel map — one bot serving several channels, each healing
# into its own repo/branch. JSON on one line; wins over the global values.
# AUTOFIX_CHANNEL_CONFIG={"#hotel-cypress-logs":{"repo":"org/hotel-specs","branch":"master","filter":"hotel"},"#flights-cypress-logs":{"repo":"org/flight-specs","filter":"flight"}}
AUTOFIX_CHANNEL_CONFIG=
# If CI messages contain multiple links, substring to pick the report one
REPORT_LINK_HINT=
