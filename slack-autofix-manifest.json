{
    "display_information": {
        "name": "QA Auto-fix",
        "description": "Threads a spec picker under failing Cypress reports; one click self-heals + opens a draft PR",
        "background_color": "#b45309"
    },
    "features": {
        "bot_user": {
            "display_name": "QA Auto-fix",
            "always_online": true
        }
    },
    "oauth_config": {
        "scopes": {
            "bot": ["chat:write", "chat:write.public", "channels:read", "channels:history"],
            "user": ["channels:read", "channels:history"]
        }
    },
    "settings": {
        "event_subscriptions": {
            "bot_events": ["message.channels"]
        },
        "interactivity": {
            "is_enabled": true
        },
        "socket_mode_enabled": true,
        "org_deploy_enabled": false,
        "token_rotation_enabled": false
    }
}
